# Claude Code OAuth token — generated by running `claude setup-token` locally.
# Valid for one year. This authenticates the claude CLI on the server.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Alternative: Anthropic API key (from console.anthropic.com/api-keys).
# Use this if the OAuth token has headless refresh issues.
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Comma-separated origins allowed to call this server.
# Add your Vercel domain here when deployed.
CORS_ORIGIN=http://localhost:5173

# Frontend: set this in Vercel project environment variables.
# VITE_API_URL=http://78.47.166.182:3001
