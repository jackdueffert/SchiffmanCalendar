# ── Claude CLI auth ────────────────────────────────────────────────────────────
# OAuth token generated by running `claude setup-token` locally (valid ~1 year)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# ── Session security ───────────────────────────────────────────────────────────
# 64-byte random hex string — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED — server will refuse to start without this.
JWT_SECRET=change-me-to-a-64-byte-random-hex-string

# ── Admin user seed ────────────────────────────────────────────────────────────
# On first startup, creates this user in the SQLite users table with a bcrypt hash.
# Remove or leave blank after the user is created — the password is never stored in plaintext.
ADMIN_USERNAME=SchiffmanCalendar
ADMIN_PASSWORD=your-password-here

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated origins. *.vercel.app is always allowed automatically.
CORS_ORIGIN=http://localhost:5173
